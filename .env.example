# ──────────────────────────────────────────────
# Elementor AI Site Generator — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your API keys:
#   cp .env.example .env.local
#
# You need at least ONE of these keys. Both are optional —
# only configure the model(s) you want to use.
# ──────────────────────────────────────────────

# Anthropic API key (for Claude Opus 4.6)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Generative AI API key (for Gemini 3.1 Pro)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key-here
